# AI Company Builder - Environment Variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ---------------------
#  Required Settings
# ---------------------

# Authentication secret (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Public URL of this server (used for CORS, cookies, admin panel API)
# For local development, leave commented out (defaults to http://localhost:3001)
# For production, set to your domain:
# PUBLIC_URL=https://your-domain.com

# Environment (development or production)
# In production, secure cookies are enabled (requires HTTPS)
# NODE_ENV=production

# Host address Docker publishes ports on (default: 127.0.0.1 = this machine only)
# Keep the default unless you have a reason not to. Known exception:
# OrbStack (<= 2.2.0) fails to forward loopback-bound ports when host and
# container ports match (https://github.com/orbstack/orbstack/issues/944) —
# set 0.0.0.0 there as a workaround.
# BIND_ADDR=0.0.0.0

# ---------------------
#  Git Server Settings
# ---------------------

# The public IP or hostname of this server (for SSH Git URLs)
# SERVER_HOST=your-server-ip

# The OS user that runs the application
# SERVER_USER=deploy

# Absolute path to Git bare repositories on the host filesystem
# HOST_REPOS_DIR=/home/deploy/ai-company-builder/data/repos
